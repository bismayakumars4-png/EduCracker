# EduCracker Backend Environment Configuration
# ================================================
# IMPORTANT: For production deployment on Render:
# 1. Set NODE_ENV=production
# 2. Update all localhost URLs to your production URLs
# 3. Update DATABASE_URL to point to your database
# 4. Generate secure JWT_SECRET and other secrets
# ================================================

# Server Configuration
PORT=10000
NODE_ENV=production

# Database Configuration (PostgreSQL - for production on Render)
# PostgreSQL connection string from Render
DATABASE_URL="postgresql://educracker_db_user:z8LxJbcxRYUFURrcce3Ydw5lMJsuhNcN@dpg-d6vvv3uuk2gs7391a84g-a/educracker_db"

# Render External URL (auto-set by Render, can override manually)
RENDER_EXTERNAL_URL=

# Frontend URL (update for production)
# Example: https://educracker.onrender.com
FRONTEND_URL=https://educracker-backend.onrender.com

# JWT Configuration (CHANGE THESE IN PRODUCTION - use secure random strings)
JWT_SECRET=educracker_secure_jwt_secret_key_change_immediately
JWT_EXPIRES_IN=7d

# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Groq AI Configuration (Primary - as per task requirements)
# Get your free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Gemini AI Configuration (Fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Update callback URL for production
GOOGLE_CALLBACK_URL=https://educracker-backend.onrender.com/api/user/auth/google/callback

# Google Drive API (for notes/achievements sync)
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Stripe Payment Gateway Configuration (Required for payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Payment Plans (prices in smallest currency unit - paise for INR)
STRIPE_MONTHLY_PRICE_ID=your_stripe_monthly_price_id
STRIPE_YEARLY_PRICE_ID=your_stripe_yearly_price_id
