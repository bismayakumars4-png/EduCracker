# EduCracker Backend Environment Configuration

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (SQLite)
DATABASE_URL="file:./dev.db"

# JWT Configuration (CHANGE THESE IN PRODUCTION)
JWT_SECRET=educracker_secure_jwt_secret_key_change_immediately
JWT_EXPIRES_IN=7d

# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/user/auth/google/callback

# Google Drive API (for notes/achievements sync)
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Stripe Payment Gateway Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Payment Plans (prices in smallest currency unit - paise for INR)
STRIPE_MONTHLY_PRICE_ID=your_stripe_monthly_price_id
STRIPE_YEARLY_PRICE_ID=your_stripe_yearly_price_id
