# EduCracker Backend Environment Variables Template
# ==================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ==================================================

# Server Configuration
PORT=10000
NODE_ENV=production

# Database Configuration
# SQLite (development): DATABASE_URL="file:./dev.db"
# PostgreSQL (production): DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DATABASE_URL="file:./dev.db"

# Render External URL (auto-set by Render, can override)
RENDER_EXTERNAL_URL=

# Frontend URL (update for production)
# Example: https://educracker.onrender.com
FRONTEND_URL=https://your-app-name.onrender.com

# JWT Configuration (IMPORTANT: Generate secure random strings for production)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_secure_random_string_here
JWT_EXPIRES_IN=7d

# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Groq AI Configuration (Primary - free API available)
# Get your free API key from https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Gemini AI Configuration (Fallback)
GEMINI_API_KEY=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Update callback URL for production: https://your-app.onrender.com/api/user/auth/google/callback
GOOGLE_CALLBACK_URL=https://your-app-name.onrender.com/api/user/auth/google/callback

# Google Drive API (for notes/achievements sync)
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=

# Stripe Payment Gateway Configuration (Required for payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment Plans (prices in smallest currency unit - paise for INR)
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
